{
  "manifest_version": 3,
  "name": "Examly Automation Extension",
  "version": "1.0.0",
  "description": "Automates course modules on Examly.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Examly Automation"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/scripts/examly_content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
